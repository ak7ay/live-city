{
	"name": "live-city",
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "tsx watch src/index.ts",
		"setup-db": "tsx src/setup-db.ts",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:coverage": "vitest --run --coverage",
		"prepare": "husky"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.118",
		"@mariozechner/pi-coding-agent": "^0.63.1",
		"croner": "^10.0.1",
		"dotenv": "^17.3.1",
		"node-appwrite": "^23.0.0",
		"pino": "^10.3.1",
		"pino-logfmt": "^1.1.3",
		"pino-pretty": "^13.1.3",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^4.1.2",
		"husky": "^9.1.7",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
