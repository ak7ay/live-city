# Appwrite
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# Logging
LOG_LEVEL=info

# Environment
NODE_ENV=development

# Agent runtime backend (optional)
#   claude - @anthropic-ai/claude-agent-sdk (DEFAULT when unset; uses Claude subscription
#            via ~/.claude/ OAuth, or ANTHROPIC_API_KEY env var as fallback)
#   pi     - @mariozechner/pi-coding-agent (legacy fallback, uses ~/.pi/agent/auth.json)
# One-time Claude auth: run `claude` once to log in (creds stored in macOS keychain).
# AGENT_RUNTIME=
